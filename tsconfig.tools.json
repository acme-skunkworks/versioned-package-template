{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "noEmit": true,
    "rootDir": "."
  },
  "exclude": ["dist", "node_modules"],
  "extends": "./tsconfig.json",
  "include": [
    "eslint.config.ts",
    "infrastructure/scripts/**/*.ts",
    "infrastructure/tests/**/*.ts",
    "vitest.config.ts"
  ]
}
