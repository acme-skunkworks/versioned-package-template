#!/bin/sh

# Pre-push: blocks direct pushes to main. All changes to main must go through
# pull requests via /send-it. See CLAUDE.md "Release workflow" for the flow.
#
# Uses printf (not echo) for colour output so escape codes render under
# strict POSIX sh (dash, busybox), where echo doesn't interpret \033.

LATEST_COMMIT_MSG=$(git log -1 --pretty=%B)
LATEST_AUTHOR=$(git log -1 --pretty=%an)
LATEST_COMMITTER=$(git log -1 --pretty=%cn)

# Skip for automated release commits (release-please release PR, SK-371).
# Match release-please's exact commit/PR-title format `chore(main): release <version>`
# (semver, optional prerelease/build suffix) rather than any `chore(...): release …`,
# so an unrelated human commit can't slip past the main-push guard.
if echo "$LATEST_COMMIT_MSG" | grep -qE "^chore\(main\): release [0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?$"; then
  printf '⏭️  Skipping pre-push check for automated release commit\n'
  exit 0
fi

# Skip for known bot identities. Check both author and committer:
# the orchestrator sets both, but other bots may set only one.
for actor in "$LATEST_AUTHOR" "$LATEST_COMMITTER"; do
  case "$actor" in
    "github-actions[bot]"|"road-runner-bot[bot]")
      printf '⏭️  Skipping pre-push check for bot commit (%s)\n' "$actor"
      exit 0
      ;;
  esac
done

while read -r _local_ref local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/heads/main)
      printf '\n\033[0;31m❌ ERROR: Direct pushes to '\''main'\'' branch are not allowed\033[0m\n\n'
      printf '   Use \033[1;33m/send-it\033[0m to push your branch and create a PR:\n\n'
      printf '   \033[1;33m1. Create a feature branch:\033[0m\n'
      printf '      git checkout -b feature/your-feature-name\n\n'
      printf '   \033[1;33m2. Run /send-it\033[0m to push, run checks, and create a PR\n\n'
      printf '   \033[1;33mTo bypass this hook (NOT RECOMMENDED):\033[0m\n'
      printf '      git push --no-verify\n\n'
      exit 1
      ;;
  esac

  # Branch deletion — skip the rest of this iteration but keep processing
  # remaining refs. (`continue`, not `exit 0`, so a deletion alongside a
  # main push doesn't silently bail out of the whole hook.)
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
done

# Workflow + YAML semantic lint. Pre-commit's lint-staged covers staged files,
# but a developer using --no-verify on commit (or amending without re-staging
# YAML) can still push broken workflow files. This is the last gate before CI.
# Best-effort: skip with install hint if the tool isn't on PATH locally — CI
# (yaml-lint job in ci.yml) still enforces.
if command -v yamllint >/dev/null 2>&1; then
  pnpm lint:yaml || exit 1
elif [ "$(uname -s)" = "Darwin" ]; then
  printf '⚠️  yamllint not installed — skipping pre-push YAML check. Install: brew install yamllint\n'
else
  printf '⚠️  yamllint not installed — skipping pre-push YAML check. Install: pip install --user yamllint==1.37.1\n'
fi

if command -v actionlint >/dev/null 2>&1; then
  pnpm lint:workflows || exit 1
elif [ "$(uname -s)" = "Darwin" ]; then
  printf '⚠️  actionlint not installed — skipping pre-push workflow check. Install: brew install actionlint\n'
else
  printf '⚠️  actionlint not installed — skipping pre-push workflow check. Install: bash <(curl -fsSL https://raw.githubusercontent.com/rhysd/actionlint/v1.7.5/scripts/download-actionlint.bash)\n'
fi

# Conventional Commits range check (A-1021 / A-982). Best-effort local feedback
# — complements CI's reusable-validate-commits gate; bypass with --no-verify.
# pre-push (not commit-msg) so WIP commits stay free until push time.
if pnpm exec commitlint --version >/dev/null 2>&1 &&
  git rev-parse --verify -q origin/main >/dev/null; then
  pnpm exec commitlint --from origin/main --to HEAD || exit 1
else
  printf '⚠️  commitlint range check not ready — skipping. Need @commitlint/cli and a fetched origin/main. Bypass: git push --no-verify\n'
fi

printf '\033[0;32m✅ Pre-push checks passed\033[0m\n'
exit 0
